DISCORD_TOKEN=your_discord_bot_token
R6DATA_API_KEY=your_r6data_api_key
DATABASE_URL=postgresql://r6bot:r6bot@localhost:5432/r6bot
ANTHROPIC_API_KEY=your_anthropic_api_key
DAILY_HOUR=22
DAILY_MINUTE=0
SNAPSHOT_HOUR=0
SNAPSHOT_MINUTE=0
COMMAND_PREFIX=!

# Feature flags (true/false)
R6_ENABLED=true       # master switch: track, stats, season, compare, leaderboard, quote
QUOTE_ENABLED=true    # !quote specifically (only active if R6_ENABLED=true)
TICKETS_ENABLED=true  # support ticket system
